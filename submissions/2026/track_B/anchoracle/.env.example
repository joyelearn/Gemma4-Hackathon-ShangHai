# Google AI Studio API Key（必填）
# 在 https://aistudio.google.com/apikey 申请
# Free tier 每日 20 次调用，演示密集场景请升级 Tier 1
GOOGLE_API_KEY=your-google-ai-studio-api-key-here

# 本地开发代理（可选，仅本地需要）
# HTTPS_PROXY=http://127.0.0.1:7890
# HTTP_PROXY=http://127.0.0.1:7890

# 调试模式（可选）
# 设为 true 时 /api/scan 会返回 _debug 字段（含 prompt 和原始模型输出）
# 生产环境务必保持关闭
# DEBUG_API=false
